# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/

# Caches / tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# OS / editor
.DS_Store

# Model artifacts (anywhere)
*.pt
*.pth
*.ckpt
*.bin
*.log

# Cursor
.cursor/

# Data (keep folders via .gitkeep, ignore contents)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# Exception: tiny smoke-test corpus is committed
!data/raw/sample_corpus.txt

# Outputs (keep folders via .gitkeep, ignore contents)
outputs/checkpoints/*
outputs/samples/*
outputs/metrics/*
outputs/logs/*
!outputs/checkpoints/.gitkeep
!outputs/samples/.gitkeep
!outputs/metrics/.gitkeep
!outputs/logs/.gitkeep
